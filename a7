import java.util.*;

class KMP
{
    static int[] lps_func(String p){
        int len = 0;
        int i = 1;
        int m = p.length();
        int[] lps = new int[m];
        while(i<m){
            if(p.charAt(i)==p.charAt(len)){
                len++;
                lps[i] = len;
                i++;
            }else{
                if(len != 0){
                    len = lps[len-1];
                }else{
                    lps[i] = 0;
                    i++;
                }
            }
        }
        return lps;
    }

    //kmp function
    static void kmp_algo(String s, String p){
        int[] lps = lps_func(p);
        int i=0, j=0;
        int n = s.length();
        int m = p.length();
        while(i<n){
            if(p.charAt(j) == s.charAt(i)){
                i++;
                j++;
            }
            if(j==m){
                System.out.println("Pattern found at index : "+ (i-j));
                j = lps[j-1];
            }else if(i<n && p.charAt(j) != s.charAt(i)){
                if(j != 0){
                    j = lps[j-1];
                }else{
                    i++;
                }
            }
        }
    }

    //main function
    public static void main(String[] args){
        String s = "abcdcabfabc";
        String pattern = "bfa";
        kmp_algo(s,pattern);
    }
}
