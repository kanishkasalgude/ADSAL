                case 9:
                    displayLeaf(root);
                    System.out.println("\nThe Leaf nodes are successfully displayed!");
                    break;

                case 10:
                    System.out.println("\nExiting the program!\n");

                default:
                    System.out.println("Enter valid choice!!\n");
            }
        }while(choice!=10);
    }
}
