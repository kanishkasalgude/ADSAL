                    delete_bst(root,del);
                    break;

                case 3:
                    System.out.println("Enter the key you want to search:");
                    int sear = sc.nextInt();
                    search_bst(root,sear);
                    break;

                case 4:
                    System.out.println("Enter the order in which you want display:\n1.preorder\n2.postorder\n3.Inorder\n4.Level order\n\nEnter your choice :");
                    int ch = sc.nextInt();
                    if(ch==1) preorder(root);
                    else if(ch==2) postorder(root);
                    else if(ch==3) inorder(root);
                    else if(ch==4) levelorder(root);
                    else System.out.println("No Valid choice inserted!\n");
                    break;

                case 5:
                    int d = depth(root);
                    System.out.println("The depth of the tree is :"+d);
