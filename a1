import java.util.*;
import java.util.Scanner;

class TreeNode
{
    int val;
    TreeNode left;
    TreeNode right;

    TreeNode(){
        left = null;
        right = null;
    }
};
public class Main{
    public static TreeNode insert(TreeNode root, int newNode){
        TreeNode newn = new TreeNode();
        newn.val = newNode;
        if(root==null){
            root = newn;
        }
        else if(newNode == root.val){
            System.out.println(newNode+" value already exists!");
        }
        else if(newNode<root.val){
            root.left = insert(root.left, newNode);
        }
        else root.right = insert(root.right, newNode);
        return root;
    }

    public static TreeNode insert_bst(TreeNode root, int newNode){
        TreeNode newn = new TreeNode();
        newn.val = newNode;
        if(root==null){
            root = newn;
            return root;
        }
        TreeNode ptr = root;
        TreeNode prev = null;
        while(ptr != null){
            prev = ptr;
            if(ptr.val == newNode){
                System.out.println(newNode+" value already exists!");
                return root;
            }else if(ptr.val<newNode){
                ptr = ptr.right;
            }else{
                ptr = ptr.left;
            }
        }
        if(newNode<prev.val){
            prev.left = newn;
        }else{
            prev.right = newn;
        }
        return root;
    }

    public static TreeNode delete_bst(TreeNode root, int target){
        if(root == null){
            System.out.println("No tree found!!");
            return root;
        }

        //first search for the key
        TreeNode ptr = root;
        TreeNode parent = null;
        while(ptr!= null && ptr.val!=target){
            parent = ptr;
            if(ptr.val>target){
                ptr = ptr.left;
            }else{
                ptr = ptr.right;
            }
        }
        if(ptr == null){
            System.out.println("Key not found!!");
            return root;
        }

        // Step 2: Case 1 — Node with no child (Leaf Node)
        if(ptr.left==null && ptr.right==null){
            if(parent==null){
                root = null;
                System.out.println("Deleted successfully!\n");
                return root;
            }
            if(parent.left==ptr){
                parent.left=null;
            }else parent.right = null;
            ptr = null;
            System.out.println("Deleted successfully!\n");
            return root;
        }

        // Step 3: Case 2 — Node with one child
        if(ptr.left==null || ptr.right==null){
            TreeNode child;
            if(ptr.left!=null) child = ptr.left;
            else child = ptr.right;
            if(parent == null) root = child;
            else if(parent.left == ptr) parent.left = child;
            else parent.right = child;
            ptr = null;
            System.out.println("Deleted successfully!\n");
            return root;
        }

        // Step 4: Case 3 — Node with two children
        TreeNode successor_parent = ptr;
        TreeNode successor = ptr.right;
        while(successor.left != null){
            successor_parent = successor;
            successor = successor.left;
        }
        ptr.val = successor.val;
        if(successor_parent.left == successor){
            successor_parent.left = successor.right;
        }else successor_parent.right = successor.right;
        successor = null;
        System.out.println("Deleted successfully!\n");
        return root;
    }

    public static TreeNode search_bst(TreeNode root, int target){
        if(root == null) {
            System.out.println("Tree is empty!!");
            return root;
        }
        TreeNode ptr = new TreeNode();
        ptr = root;
        while(ptr!=null){
            if(target == ptr.val){
                System.out.println("Key found in the tree!");
                return ptr;
            }
            else if(target < ptr.val){
                ptr = ptr.left;
            }else ptr = ptr.right;
        }
        System.out.println("Key not found!!");
        return null;
    }

    //display

    public static void inorder(TreeNode root){
        if(root == null) return;
        inorder(root.left);
        System.out.printf(root.val+" ");
        inorder(root.right);
    }

    public static void preorder(TreeNode root){
        if(root == null) return;
        System.out.printf(root.val+" ");
        preorder(root.left);
        preorder(root.right);
    }

    public static void postorder(TreeNode root){
        if(root == null) return;
        postorder(root.left);
        postorder(root.right);
        System.out.printf(root.val+" ");
    }

    public static void levelorder(TreeNode root){
        if(root == null){
            System.out.println("Tree not found!\n");
            return;
        }
        Queue<TreeNode> q = new ArrayDeque<>();
        q.add(root);
        while(!q.isEmpty()){
            TreeNode ptr = q.poll();
            System.out.printf(ptr.val+" ");
            if(ptr.left!=null) q.add(ptr.left);
            if(ptr.right!=null) q.add(ptr.right);
        }
    }

    //depth of the tree
    public static int depth(TreeNode root) {
        if (root == null) return 0;

        int lefth = depth(root.left);
        int righth = depth(root.right);

        return 1 + Math.max(lefth, righth);
    }

    //mirror the given tree
        public static void mirror(TreeNode root){
        if(root==null) return;
        TreeNode temp = root.left;
        root.left = root.right;
        root.right = temp;
        mirror(root.left);
        mirror(root.right);
    }

    //create a COPY of the given tree
    public static TreeNode copy(TreeNode root){
        if(root==null) return null;
        TreeNode temp = new TreeNode();
        temp.val = root.val;
        temp.left = copy(root.left);
        temp.right = copy(root.right);
        return temp;//System.out.printf("Inorder display of copy : ");
        //inorder(temp);
    }

    //Display parent with children
    public static void displayParent(TreeNode root){
        if(root==null) return;
        if(root.left!= null || root.right!=null){
            System.out.printf("\nParent :"+root.val);
            if(root.left!= null){
                System.out.println("\nLeft Child :"+root.left.val);
            }else System.out.println("\nLeft Child :null");
            if(root.right!= null){
                System.out.println("Right Child :"+root.right.val);
            }else System.out.println("   Right Child :null");
        }
        displayParent(root.left);
        displayParent(root.right);
    }

    //display leaf nodes
    public static void displayLeaf(TreeNode root){
        if(root==null) return;
        if(root.left==null && root.right==null){
            System.out.printf(root.val + " ");
        }
        displayLeaf(root.left);
        displayLeaf(root.right);
    }

