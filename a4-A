Problem Statement : A city transportation department is developing a navigation system to help users find
efficient routes between different locations. Represent the city map as a graph, having node
as each location (place) and Each road connecting two locations is an edge. Explore
possible routes using Depth-First Search (DFS) and Breadth-First Search (BFS).
*/

import java.util.*;

public class Main {
    static HashMap<Integer, ArrayList<Integer>> adj = new HashMap<>();
    static HashMap<Integer, Boolean> visited = new HashMap<>();

    static void addEdge(int u, int v) {
        adj.putIfAbsent(u, new ArrayList<>());
        adj.putIfAbsent(v, new ArrayList<>());
        adj.get(u).add(v);
        adj.get(v).add(u);
    }

    //depth first search
    static void dfs(int node) {
        visited.put(node, true);
        System.out.print(node + " ");
        for (int n : adj.keySet()) {
            if (!visited.getOrDefault(n, false)) {
                dfs(n);
            }
        }
    }

    //breadth first search
    static void bfs(int node) {
        Queue<Integer> q = new LinkedList<>();
        q.add(node);
        visited.put(node, true);
        while (!q.isEmpty()) {
            int temp = q.poll();
            System.out.print(temp + " ");
            for (int n : adj.get(temp)) {
                if (!visited.getOrDefault(n, false)) {
                    q.add(n);
                    visited.put(n, true);
                }
            }
        }
    }

    //main function
    public static void main(String[] args) {
        addEdge(1, 2);
        addEdge(1, 3);
        addEdge(2, 4);
        addEdge(3, 5);
        dfs(1);
        visited.clear();
        System.out.println();
        bfs(1);
    }
}
